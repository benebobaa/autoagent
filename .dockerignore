# ============================================================
# Docker Build Context Exclusions
# Keep the build context small by excluding unnecessary files
# ============================================================

# Dependencies
node_modules/

# Build output
dist/

# Development files
.git/
.gitignore
*.md
!README.md

# Environment files (use .env.docker for Docker)
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Test coverage
coverage/

# Temporary files
tmp/
temp/
*.tmp
