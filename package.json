{
  "name": "solana-yield-agent",
  "version": "0.1.0",
  "description": "Solana DeFi yield optimization agent — Phase 1 MVP",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/agent.ts",
    "cli": "tsx src/cli/index.ts",
    "confirm": "tsx src/cli/index.ts confirm",
    "test": "vitest run",
    "test:isolated": "TEST_DATABASE_URL=${TEST_DATABASE_URL:-postgresql://yield_agent_test:yield_agent_test@localhost:5433/yield_agent_test} vitest run",
    "test:watch": "vitest",
    "test:db:up": "docker compose -p solana-yield-agent-test -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -p solana-yield-agent-test -f docker-compose.test.yml down -v",
    "test:db:logs": "docker compose -p solana-yield-agent-test -f docker-compose.test.yml logs -f postgres_test",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "db:migrate": "node-pg-migrate up --migration-file-language sql --migrations-dir migrations --database-url $DATABASE_URL",
    "postinstall": "sh scripts/patch-marginfi-idl.sh"
  },
  "dependencies": {
    "@kamino-finance/klend-sdk": "^7.3.21",
    "@kamino-finance/kliquidity-sdk": "^11.0.3",
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.38",
    "@langchain/deepseek": "^1.0.21",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/openai": "^1.4.1",
    "@langchain/openrouter": "^0.2.0",
    "@meteora-ag/dlmm": "^1.9.4",
    "@mrgnlabs/marginfi-client-v2": "^6.4.1",
    "@project-serum/anchor": "^0.26.0",
    "@solana/spl-stake-pool": "^1.1.8",
    "@solana/web3.js": "^1.95.0",
    "axios": "^1.7.0",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "node-pg-migrate": "^8.0.4",
    "node-telegram-bot-api": "^0.66.0",
    "pg": "^8.20.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
