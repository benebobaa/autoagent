# ============================================================
# Solana Yield Agent — Environment Variables
# Copy to .env and fill in real values before running.
# ============================================================

# ── Solana RPC ──────────────────────────────────────────────
# Helius free tier is recommended — public mainnet-beta hits rate limits with Marginfi.
# Sign up free at https://helius.dev and replace the key below.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# ── Wallet ──────────────────────────────────────────────────
# Agent wallet public key (READ-ONLY in Phase 1 — used for balance checks only, never signs)
AGENT_WALLET_ADDRESS=

# ── Telegram ────────────────────────────────────────────────
# Bot credentials (required for Telegram reports; omit to use stdout fallback)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LLM API Keys ───────────────────────────────────────────
# At least one is required for the LangGraph supervisor + agents.
# The configured llm.default.provider (or override provider) determines which key is used.
# Uncomment the provider(s) you want to use.
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
# DEEPSEEK_API_KEY=your_deepseek_key_here
# OPENROUTER_API_KEY=your_openrouter_key_here

# ── Embedding API Key ─────────────────────────────────────
# Used for RAG embeddings when rag.embedding_provider is 'openai'.
# Can be the same as OPENAI_API_KEY or a separate key.
# EMBEDDING_API_KEY=your_embedding_key_here

# ── Protocol API Base URLs ──────────────────────────────────
# These have sensible defaults — only override if you need a custom endpoint.
DEFILLAMA_BASE_URL=https://yields.llama.fi
KAMINO_API_BASE_URL=https://api.kamino.finance
METEORA_API_BASE_URL=https://dlmm.datapi.meteora.ag

# ── Jupiter Swap API ───────────────────────────────────────
# Required for swap functionality. Get free key at https://portal.jup.ag
JUPITER_API_KEY=

# ── Marginfi ────────────────────────────────────────────────
# Environment: 'production' | 'staging'
MARGINFI_ENV=production

# ── Agent Behavior ──────────────────────────────────────────
# DRY_RUN=true → executor prints proposed action but skips simulation and never submits
DRY_RUN=true
PAPER_TRADING=true
TOTAL_CAPITAL_USD=500

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# ── Risk Tier System ─────────────────────────────────────────
ACTIVE_TIERS=2,5,8
TIER_2_ALLOCATION=0.50
TIER_5_ALLOCATION=0.30
TIER_8_ALLOCATION=0.20
ENABLE_MEME_DISCOVERY=false
DISCOVERY_SCAN_INTERVAL_MIN=20
GLOBAL_MAX_DRAWDOWN_PCT=0.10
MAX_AGGRESSIVE_TIER_PCT=0.35
MONITOR_CHECK_INTERVAL=60
MONITOR_CHECK_INTERVAL_ACTIVE=180

# ── External APIs ────────────────────────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string. Use docker-compose.yml for local pgvector setup.
DATABASE_URL=postgresql://yield_agent:yield_agent@localhost:5432/yield_agent

# Dedicated isolated Postgres for Vitest / DB-backed tests.
TEST_DATABASE_URL=postgresql://yield_agent_test:yield_agent_test@localhost:5433/yield_agent_test

# ── LangSmith (optional — enables LangGraph tracing) ────────
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=your_langsmith_key_here
# LANGSMITH_PROJECT=auto-agent
